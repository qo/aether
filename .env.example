AETHER_API_HOST=127.0.0.1
AETHER_API_PORT=8000
AETHER_WEB_PORT=3000
AETHER_SERIAL_PORT=
# Default firmware ships at 921600 baud (was 115200). Drop to 115200 only
# if you flashed an older RX firmware build, or if your USB-UART bridge
# (CP2102 / CH9102 / CH340) is unreliable above ~460800 baud.
AETHER_BAUD=921600
AETHER_REPLAY_PATH=
AETHER_DATA_DIR=./data
AETHER_SESSION_DB=./data/aether.sqlite
AETHER_KB_ROOT=./docs
NEXT_PUBLIC_AETHER_API=http://127.0.0.1:8000
NEXT_PUBLIC_AETHER_WS=ws://127.0.0.1:8000/ws/live
