{
  "name": "aether",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.15.4",
  "workspaces": [
    "apps/web",
    "packages/protocol/typescript"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @aether/web",
    "web:dev": "npm run dev --workspace @aether/web",
    "web:build": "npm run build --workspace @aether/web",
    "api:dev": "python -m uvicorn apps.api.src.main:app --reload --host 127.0.0.1 --port 8000 --ws-ping-interval 30 --ws-ping-timeout 30",
    "test": "npm run test:protocol && npm run check:no-fake-data",
    "test:protocol": "node tests/e2e/protocol-schema.test.mjs",
    "check:no-fake-data": "node scripts/no_nonreal_data_check.mjs",
    "lint": "npm run lint --workspace @aether/web"
  },
  "dependencies": {
    "@types/three": "^0.184.1",
    "three": "^0.184.0"
  }
}
