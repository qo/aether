{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aether.local/schemas/csi_frame.v1.json",
  "title": "Raw CSI Frame",
  "type": "object",
  "required": [
    "schema_version",
    "session_id",
    "device_id",
    "device_role",
    "seq",
    "ts_device_us",
    "ts_host_ns",
    "channel",
    "rssi_dbm",
    "noise_floor_dbm",
    "sig_mode",
    "cwb",
    "secondary_channel",
    "stbc",
    "first_word_invalid",
    "payload_len",
    "raw_iq_int8",
    "source_mode"
  ],
  "properties": {
    "schema_version": { "const": "csi_frame.v1" },
    "session_id": { "type": "string", "minLength": 1 },
    "device_id": { "type": "string", "minLength": 1 },
    "device_role": { "const": "rx" },
    "seq": { "type": "integer", "minimum": 0 },
    "ts_device_us": { "type": "integer", "minimum": 0 },
    "ts_host_ns": { "type": "integer", "minimum": 0 },
    "channel": { "type": "integer", "minimum": 1, "maximum": 14 },
    "rssi_dbm": { "type": "integer", "minimum": -127, "maximum": 20 },
    "noise_floor_dbm": { "type": "integer", "minimum": -127, "maximum": 20 },
    "sig_mode": { "type": "integer" },
    "cwb": { "type": "integer" },
    "secondary_channel": { "type": "integer" },
    "stbc": { "type": "integer" },
    "first_word_invalid": { "type": "boolean" },
    "payload_len": { "type": "integer", "minimum": 0 },
    "raw_iq_int8": {
      "type": "array",
      "items": { "type": "integer", "minimum": -128, "maximum": 127 }
    },
    "source_mode": { "enum": ["LIVE", "REPLAY"] }
  },
  "additionalProperties": false
}
