{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aether.local/schemas/derived_window.v1.json",
  "title": "Derived CSI Window",
  "type": "object",
  "required": [
    "schema_version",
    "session_id",
    "device_id",
    "window_start_ns",
    "window_end_ns",
    "packet_count",
    "packet_rate_hz",
    "mean_rssi_dbm",
    "subcarrier_count",
    "amplitude_mean",
    "amplitude_std",
    "phase_unwrapped_mean",
    "motion_score",
    "occupancy_score",
    "respiration_bpm",
    "respiration_confidence",
    "anomaly_score",
    "quality_score",
    "source_mode"
  ],
  "properties": {
    "schema_version": { "const": "derived_window.v1" },
    "session_id": { "type": "string", "minLength": 1 },
    "device_id": { "type": "string", "minLength": 1 },
    "window_start_ns": { "type": "integer", "minimum": 0 },
    "window_end_ns": { "type": "integer", "minimum": 0 },
    "packet_count": { "type": "integer", "minimum": 0 },
    "packet_rate_hz": { "type": "number", "minimum": 0 },
    "mean_rssi_dbm": { "type": "number" },
    "subcarrier_count": { "type": "integer", "minimum": 0 },
    "amplitude_mean": { "type": "array", "items": { "type": "number" } },
    "amplitude_std": { "type": "array", "items": { "type": "number" } },
    "phase_unwrapped_mean": { "type": "array", "items": { "type": "number" } },
    "phase_unwrapped_std": {
      "type": ["array", "null"],
      "items": { "type": "number" }
    },
    "motion_score_amplitude": { "type": ["number", "null"], "minimum": 0 },
    "motion_score_phase": { "type": ["number", "null"], "minimum": 0 },
    "responsive_subcarriers": {
      "type": "array",
      "items": { "type": "integer", "minimum": 0 }
    },
    "motion_score": { "type": "number", "minimum": 0 },
    "occupancy_score": { "type": "number", "minimum": 0, "maximum": 1 },
    "respiration_bpm": { "type": ["number", "null"], "minimum": 0 },
    "respiration_confidence": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
    "anomaly_score": { "type": "number", "minimum": 0 },
    "quality_score": { "type": "number", "minimum": 0, "maximum": 1 },
    "respiration_bpm_acf": { "type": ["number", "null"], "minimum": 0 },
    "respiration_harmonic_prominence": { "type": ["number", "null"] },
    "respiration_tracked_bpm": { "type": ["number", "null"], "minimum": 0 },
    "heart_rate_proxy_bpm": { "type": ["number", "null"], "minimum": 0 },
    "heart_rate_proxy_confidence": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
    "heart_rate_proxy_bpm_acf": { "type": ["number", "null"], "minimum": 0 },
    "heart_rate_proxy_harmonic_prominence": { "type": ["number", "null"] },
    "heart_rate_proxy_tracked_bpm": { "type": ["number", "null"], "minimum": 0 },
    "fidget_score": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
    "biorhythm_window_seconds": { "type": ["number", "null"], "minimum": 0 },
    "biorhythm_sample_rate_hz": { "type": ["number", "null"], "minimum": 0 },
    "biorhythm_signal_path": { "type": ["string", "null"] },
    "stillness_gated": { "type": "boolean" },
    "looks_like_respiration_harmonic": { "type": "boolean" },
    "packet_loss_ratio": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
    "first_word_invalid_ratio": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
    "jitter_ms": { "type": ["number", "null"], "minimum": 0 },
    "expected_packet_rate_hz": { "type": ["number", "null"], "minimum": 0 },
    "baseline_calibrated": { "type": "boolean" },
    "source_mode": { "enum": ["LIVE", "REPLAY"] }
  },
  "additionalProperties": false
}
